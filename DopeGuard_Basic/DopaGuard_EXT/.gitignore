# ==========================================================
# 🧠 DopaGuard Extension – .gitignore
# Keeps build, cache, and secrets out of Git
# ==========================================================

# Node modules & build output
node_modules/
extension/
dist/
build/
*.bundle.js

# Dependency locks (optional)
package-lock.json

# Temporary build/test artifacts
*.log
*.tmp
*.bak
*.old
*.swp

# macOS & Windows system junk
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# IDE/editor caches
.vscode/
.idea/
*.code-workspace

# TensorFlow / NSFW.js cache
__pycache__/
.cache/
tmp/
model/
models/
tfjs_model/

# NPM debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local config or secrets (just in case)
.env
.env.local
.env.development
.env.production

# Backup / test data
porn_blocker.txt
test/
tests/
*.test.js

# VSCode workspace state
.history/
.vscode/settings.json

# Optional: if using screenshots or demo outputs
screenshots/
*.png
*.jpg

# ==========================================================
# End of file
# ==========================================================
