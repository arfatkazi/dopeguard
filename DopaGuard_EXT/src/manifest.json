{
  "manifest_version": 3,
  "name": "DopeGuard 🧠 AI Shield",
  "version": "1.0.0",
  "description": "Blocks NSFW sites, base64 images, and videos using AI. Focused. Disciplined. Protected.",
  "permissions": ["storage", "scripting", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.bundle.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DopeGuard Shield"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_entry.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["dopeguard.jpg", "blocked.jpg"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
